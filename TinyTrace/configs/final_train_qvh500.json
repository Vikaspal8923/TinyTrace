{
  "train_script": "TinyTrace/scripts/train_tinytrace.py",
  "model_config": "TinyTrace/configs/tinytrace_qvhighlights_phase_a.json",
  "train_dataset_json": "final_qvhighlights_tinytrace/annotations/tinytrace_train.json",
  "val_dataset_json": "final_qvhighlights_tinytrace/annotations/tinytrace_val.json",
  "output_dir": "TinyTrace/outputs-qvh-phase-a-v1",
  "frame_cache_dir": "TinyTrace/.cache/frames_qvh-phase-a-32",
  "device": "cuda",
  "epochs": 15,
  "batch_size": 2,
  "dataset_size": 128,
  "lr": 0.0003,
  "weight_decay": 0.01,
  "gradient_clip": 1.0,
  "warmup_ratio": 0.05,
  "min_lr_ratio": 0.1,
  "amp": "auto",
  "accumulation_steps": 4,
  "early_stopping_patience": 3,
  "early_stopping_min_delta": 0.0,
  "early_stopping_min_epochs": 5,
  "monitor": "qvh_mAP",
  "monitor_mode": "max",
  "save_every": 1,
  "checkpoint_keep": 3,
  "prediction_every": 1,
  "prediction_samples": 2,
  "metrics_every": 1,
  "num_workers": 2,
  "log_every": 25,
  "max_steps_per_epoch": 0,
  "stage2_start_epoch": 0,
  "stage2_visual_lr_scale": 0.05,
  "stage2_unfreeze_strategy": "conv_exp",
  "seed": 7,
  "deterministic": true,
  "allow_random_frames": false,
  "resume": ""
}
