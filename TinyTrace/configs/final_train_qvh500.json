{
  "train_script": "TinyTrace/scripts/train_tinytrace.py",
  "model_config": "TinyTrace/configs/tinytrace_baseline.json",
  "train_dataset_json": "final_qvhighlights_tinytrace/annotations/tinytrace_train.json",
  "val_dataset_json": "final_qvhighlights_tinytrace/annotations/tinytrace_val.json",
  "output_dir": "TinyTrace/outputs-qvh-final",
  "frame_cache_dir": "TinyTrace/.cache/frames_qvh500",
  "device": "cuda",
  "epochs": 10,
  "batch_size": 2,
  "lr": 0.0003,
  "weight_decay": 0.01,
  "gradient_clip": 1.0,
  "save_every": 1,
  "prediction_every": 1,
  "prediction_samples": 2,
  "metrics_every": 1,
  "num_workers": 2,
  "log_every": 25,
  "stage2_start_epoch": 6,
  "stage2_visual_lr_scale": 0.05,
  "stage2_unfreeze_strategy": "conv_exp",
  "seed": 7
}
